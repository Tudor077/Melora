{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Melora",
  "version": "0.3.0",
  "identifier": "com.melora.app",
  "build": {
    "beforeDevCommand": "npm run dev --workspace @melora/web",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build --workspace @melora/web",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Melora",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "melora"
        ]
      },
      "mobile": [
        {
          "scheme": [
            "melora"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Melora",
    "licenseFile": "EULA.rtf",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.ico"
    ]
  }
}
